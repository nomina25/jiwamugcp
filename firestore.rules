rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admins Collection
    match /admins/{email} {
      allow read, write: if true;
    }
    
    // Test Results Collection
    match /test_results/{resultId} {
      allow read, write: if true;
    }
    
    // Subscribers Collection
    match /subscribers/{subId} {
      allow read, write: if true;
    }
    
    // Articles Collection
    match /articles/{articleId} {
      allow read, write: if true;
    }
    
    // Videos Collection
    match /videos/{videoId} {
      allow read, write: if true;
    }
    
    // Books Collection
    match /books/{bookSlug} {
      allow read, write: if true;
    }
    
    // Magazines Collection
    match /magazines/{magId} {
      allow read, write: if true;
    }
    
    // Projects Collection
    match /projects/{projectId} {
      allow read, write: if true;
    }
    
    // Downloads Collection
    match /downloads/{downloadId} {
      allow read, write: if true;
    }
    
    // Trainers Collection
    match /trainers/{trainerId} {
      allow read, write: if true;
    }
    
    // Pamong Collection
    match /pamong/{pamongId} {
      allow read, write: if true;
    }
    
    // Classes Collection
    match /classes/{classId} {
      allow read, write: if true;
    }

    // Alumni Collection
    match /alumni/{alumniId} {
      allow read, write: if true;
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
